@page "/fields/{PropertyId:guid}"
@using AgroSolutions.Dashboard.Services
@using AgroSolutions.Dashboard.Models
@using System.ComponentModel.DataAnnotations
@inject FieldService FieldService
@inject PropertyService PropertyService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>Talhões - AgroSolutions</PageTitle>

<div class="mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/properties">Propriedades</a></li>
            <li class="breadcrumb-item active">@propertyName</li>
        </ol>
    </nav>
</div>

<div class="dashboard-header mb-4">
    <div>
        <h2 class="mb-1">Talhões - @propertyName</h2>
        <p class="text-muted mb-0">Gerencie os talhões desta propriedade</p>
    </div>
    <button class="btn btn-modern btn-modern-primary" @onclick="() => showCreateModal = true">
        + Novo Talhão
    </button>
</div>

@if (propertyTotalArea > 0)
{
    <div class="filter-section mb-4">
        <div class="row">
            <div class="col-md-4">
                <div class="area-info">
                    <span class="area-label">📏 Área Total:</span>
                    <span class="area-value">@propertyTotalArea.ToString("N2") ha</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="area-info">
                    <span class="area-label">✓ Área Utilizada:</span>
                    <span class="area-value text-info">@usedArea.ToString("N2") ha</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="area-info">
                    <span class="area-label">🟢 Área Disponível:</span>
                    <span class="area-value text-success">@availableArea.ToString("N2") ha</span>
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
        <p class="mt-3 text-muted">Carregando...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (fields.Count == 0)
{
    <div class="alert alert-info">
        Nenhum talhão cadastrado. Clique em "Novo Talhão" para começar.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var field in fields)
        {
            <div class="col-md-6 col-lg-4">
                <div class="field-card">
                    <div class="field-card-header">
                        <h5 class="mb-0">🌾 @field.Name</h5>
                    </div>
                    <div class="field-card-body">
                        <div class="property-info">
                            <span class="property-label">🌱 Cultura:</span>
                            <span class="property-value">@field.Culture</span>
                        </div>
                        <div class="property-info">
                            <span class="property-label">📐 Área:</span>
                            <span class="property-value">@field.Area.ToString("N2") hectares</span>
                        </div>
                        <div class="mt-2">
                            <span class="badge bg-success">Ativo</span>
                        </div>
                    </div>
                    <div class="field-card-footer">
                        <button class="btn btn-sm btn-modern-primary w-100 mb-2"
                                @onclick="() => SimulateSensorData(field.Id)"
                                disabled="@(isSimulating && simulatingFieldId == field.Id)">
                            @if (isSimulating && simulatingFieldId == field.Id)
                            {
                                <span>Simulando...</span>
                            }
                            else
                            {
                                <span>📊 Simular Dados de Sensor</span>
                            }
                        </button>
                        <button class="btn btn-sm btn-outline-danger w-100"
                                @onclick="() => ShowDeleteConfirm(field.Id)">
                            🗑️ Excluir Talhão
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (showCreateModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Novo Talhão</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(createError))
                    {
                        <div class="alert alert-danger">@createError</div>
                    }
                    <EditForm Model="@newField" OnValidSubmit="@CreateField">
                        <DataAnnotationsValidator />

                        <div class="alert alert-info mb-3">
                            <strong>Área da Propriedade:</strong> @propertyTotalArea.ToString("N2") ha<br />
                            <strong>Área Usada:</strong> @usedArea.ToString("N2") ha<br />
                            <strong>Área Disponível:</strong> @availableArea.ToString("N2") ha
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nome do Talhão</label>
                            <InputText @bind-Value="newField.Name" class="form-control" placeholder="Talhão Norte" />
                            <ValidationMessage For="@(() => newField.Name)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Cultura</label>
                            <InputText @bind-Value="newField.Culture" class="form-control" placeholder="Soja, Milho, etc." />
                            <ValidationMessage For="@(() => newField.Culture)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Área (hectares)</label>
                            <InputNumber @bind-Value="newField.Area" class="form-control" />
                            <ValidationMessage For="@(() => newField.Area)" class="text-danger" />
                            <small class="text-muted">Máximo disponível: @availableArea.ToString("N2") ha</small>
                        </div>

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                            <button type="submit" class="btn btn-modern-primary" disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span>Salvando...</span>
                                }
                                else
                                {
                                    <span>Salvar</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir este talhão?</p>
                    <p class="text-muted mb-0">Esta ação não pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span>Excluindo...</span>
                        }
                        else
                        {
                            <span>Sim, Excluir</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid PropertyId { get; set; }

    private List<Field> fields = new();
    private string propertyName = "";
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string errorMessage = string.Empty;
    private string createError = string.Empty;

    private double propertyTotalArea = 0;
    private double usedArea = 0;
    private double availableArea = 0;

    private bool isSimulating = false;
    private Guid? simulatingFieldId = null;

    private bool showDeleteModal = false;
    private Guid? fieldToDelete = null;
    private bool isDeleting = false;

    private CreateFieldModel newField = new();

    protected override async Task OnInitializedAsync()
    {
        while (!AuthState.IsInitialized)
        {
            await Task.Delay(50);
        }

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadPropertyName();
        await LoadFields();
    }

    private async Task LoadPropertyName()
    {
        try
        {
            var properties = await PropertyService.GetUserPropertiesAsync();
            var property = properties.FirstOrDefault(p => p.Id == PropertyId);
            propertyName = property?.Name ?? "Propriedade";
            propertyTotalArea = property?.TotalArea ?? 0;

            usedArea = fields.Sum(f => f.Area);
            availableArea = propertyTotalArea - usedArea;
        }
        catch
        {
            propertyName = "Propriedade";
            propertyTotalArea = 0;
        }
    }

    private async Task LoadFields()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            fields = await FieldService.GetPropertyFieldsAsync(PropertyId);

            usedArea = fields.Sum(f => f.Area);
            availableArea = propertyTotalArea - usedArea;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateField()
    {
        try
        {
            isCreating = true;
            createError = string.Empty;

            if (newField.Area > availableArea)
            {
                ToastService.ShowError($"Área do talhão ({newField.Area:N2} ha) excede a área disponível ({availableArea:N2} ha)");
                return;
            }

            var success = await FieldService.CreateFieldAsync(
                PropertyId,
                newField.Name,
                newField.Culture,
                newField.Area
            );

            if (success)
            {
                ToastService.ShowSuccess("Talhão criado com sucesso!");
                CloseModal();
                await LoadFields();
            }
            else
            {
                ToastService.ShowError("Erro ao criar talhão");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
        finally
        {
            isCreating = false;
        }
    }

    private void CloseModal()
    {
        showCreateModal = false;
        newField = new CreateFieldModel();
        createError = string.Empty;
    }

    private async Task SimulateSensorData(Guid fieldId)
    {
        try
        {
            isSimulating = true;
            simulatingFieldId = fieldId;

            var success = await FieldService.SimulateSensorDataAsync(fieldId);

            if (success)
            {
                ToastService.ShowSuccess("Dados de sensor simulados com sucesso! Verifique o Dashboard.");
            }
            else
            {
                ToastService.ShowError("Erro ao simular dados de sensor");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
        finally
        {
            isSimulating = false;
            simulatingFieldId = null;
        }
    }

    private void ShowDeleteConfirm(Guid fieldId)
    {
        fieldToDelete = fieldId;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        fieldToDelete = null;
        showDeleteModal = false;
    }

    private async Task ConfirmDelete()
    {
        if (!fieldToDelete.HasValue) return;

        try
        {
            isDeleting = true;

            var success = await FieldService.DeleteFieldAsync(fieldToDelete.Value);

            if (success)
            {
                ToastService.ShowSuccess("Talhão excluído com sucesso!");
                CloseDeleteModal();
                await LoadFields();
            }
            else
            {
                ToastService.ShowError("Erro ao excluir talhão");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }

    private class CreateFieldModel
    {
        [Required(ErrorMessage = "Nome é obrigatório")]
        [MinLength(3, ErrorMessage = "Nome deve ter pelo menos 3 caracteres")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Cultura é obrigatória")]
        [MinLength(2, ErrorMessage = "Cultura deve ter pelo menos 2 caracteres")]
        public string Culture { get; set; } = string.Empty;

        [Required(ErrorMessage = "Área é obrigatória")]
        [Range(0.01, double.MaxValue, ErrorMessage = "Área deve ser maior que zero")]
        public double Area { get; set; }
    }
}