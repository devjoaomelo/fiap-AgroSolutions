@layout PublicLayout
@page "/"
@inject NavigationManager Navigation

<PageTitle>AgroSolutions</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4">🌾 AgroSolutions</h1>
            <p class="lead">Plataforma IoT para Agricultura de Precisão</p>
            <hr class="my-4" />
            <p>Monitore suas plantações em tempo real com alertas inteligentes</p>
            <button class="btn btn-primary btn-lg" @onclick="GoToLogin">
                Acessar Sistema
            </button>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-4 text-center">
            <div class="card">
                <div class="card-body">
                    <h3>💧</h3>
                    <h5>Monitoramento de Umidade</h5>
                    <p>Alertas quando o solo está muito seco</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card">
                <div class="card-body">
                    <h3>🌡️</h3>
                    <h5>Controle de Temperatura</h5>
                    <p>Detecção de temperaturas extremas</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card">
                <div class="card-body">
                    <h3>🌧️</h3>
                    <h5>Gestão de Precipitação</h5>
                    <p>Alertas de chuvas fortes</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}