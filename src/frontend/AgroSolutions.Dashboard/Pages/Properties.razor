@page "/properties"
@using AgroSolutions.Dashboard.Services
@using AgroSolutions.Dashboard.Models
@using System.ComponentModel.DataAnnotations
@inject PropertyService PropertyService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>Minhas Propriedades - AgroSolutions</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <h2 class="mb-1">Minhas Propriedades</h2>
        <p class="text-muted mb-0">Gerencie suas propriedades rurais</p>
    </div>
    <button class="btn btn-modern btn-modern-primary" @onclick="() => showCreateModal = true">
        + Nova Propriedade
    </button>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
        <p class="mt-3 text-muted">Carregando...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (properties.Count == 0)
{
    <div class="alert alert-info">
        Nenhuma propriedade cadastrada. Clique em "Nova Propriedade" para começar.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var property in properties)
        {
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-card-header">
                        <h5 class="mb-0">🏡 @property.Name</h5>
                    </div>
                    <div class="property-card-body">
                        <div class="property-info">
                            <span class="property-label">📍 Localização:</span>
                            <span class="property-value">@property.Location</span>
                        </div>
                        <div class="property-info">
                            <span class="property-label">📏 Área Total:</span>
                            <span class="property-value">@property.TotalArea.ToString("N2") hectares</span>
                        </div>
                    </div>
                    <div class="property-card-footer">
                        <div class="d-flex gap-2">
                            <a href="/fields/@property.Id" class="btn btn-sm btn-modern-primary flex-fill">
                                Ver Talhões →
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteConfirm(property.Id)">
                                🗑️ Deletar Propriedade
                            </button>
                            </div>
                        </div>
                    </div>
                </div>
        }
    </div>
}

@if (showCreateModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nova Propriedade</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(createError))
                    {
                        <div class="alert alert-danger">@createError</div>
                    }
                    <EditForm Model="@newProperty" OnValidSubmit="@CreateProperty">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nome da Propriedade</label>
                            <InputText @bind-Value="newProperty.Name" class="form-control" placeholder="Fazenda São José" />
                            <ValidationMessage For="@(() => newProperty.Name)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Localização</label>
                            <InputText @bind-Value="newProperty.Location" class="form-control" placeholder="Campinas, SP" />
                            <ValidationMessage For="@(() => newProperty.Location)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Área Total (hectares)</label>
                            <InputNumber @bind-Value="newProperty.TotalArea" class="form-control" />
                            <ValidationMessage For="@(() => newProperty.TotalArea)" class="text-danger" />
                        </div>

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                            <button type="submit" class="btn btn-modern-primary" disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span>Salvando...</span>
                                }
                                else
                                {
                                    <span>Salvar</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar Exclusão</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir esta propriedade?</p>
                    <p class="text-danger mb-0">
                        <strong>Atenção:</strong> Todos os talhões desta propriedade também serão excluídos!
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span>Excluindo...</span>
                        }
                        else
                        {
                            <span>Sim, Excluir</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Property> properties = new();
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string errorMessage = string.Empty;
    private string createError = string.Empty;
    private bool showDeleteModal = false;
    private Guid? propertyToDelete = null;
    private bool isDeleting = false;

    private CreatePropertyModel newProperty = new();

    protected override async Task OnInitializedAsync()
    {
        while (!AuthState.IsInitialized)
        {
            await Task.Delay(50);
        }

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadProperties();
    }

    private async Task LoadProperties()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            properties = await PropertyService.GetUserPropertiesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateProperty()
    {
        try
        {
            isCreating = true;
            createError = string.Empty;

            var success = await PropertyService.CreatePropertyAsync(
                newProperty.Name,
                newProperty.Location,
                newProperty.TotalArea
            );

            if (success)
            {
                ToastService.ShowSuccess("Propriedade criada com sucesso!");
                CloseModal();
                await LoadProperties();
            }
            else
            {
                ToastService.ShowError("Erro ao criar propriedade");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
        finally
        {
            isCreating = false;
        }
    }

    private void ShowDeleteConfirm(Guid propertyId)
    {
        propertyToDelete = propertyId;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        propertyToDelete = null;
        showDeleteModal = false;
    }

    private async Task ConfirmDelete()
    {
        if (!propertyToDelete.HasValue) return;

        try
        {
            isDeleting = true;

            var success = await PropertyService.DeletePropertyAsync(propertyToDelete.Value);

            if (success)
            {
                ToastService.ShowSuccess("Propriedade excluída com sucesso!");
                CloseDeleteModal();
                await LoadProperties();
            }
            else
            {
                ToastService.ShowError("Erro ao excluir propriedade");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CloseModal()
    {
        showCreateModal = false;
        newProperty = new CreatePropertyModel();
        createError = string.Empty;
    }

    private class CreatePropertyModel
    {
        [Required(ErrorMessage = "Nome é obrigatório")]
        [MinLength(3, ErrorMessage = "Nome deve ter pelo menos 3 caracteres")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Localização é obrigatória")]
        [MinLength(3, ErrorMessage = "Localização deve ter pelo menos 3 caracteres")]
        public string Location { get; set; } = string.Empty;

        [Required(ErrorMessage = "Área é obrigatória")]
        [Range(0.01, double.MaxValue, ErrorMessage = "Área deve ser maior que zero")]
        public double TotalArea { get; set; }
    }
}