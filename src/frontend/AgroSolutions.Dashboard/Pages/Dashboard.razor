@page "/dashboard"
@using AgroSolutions.Dashboard.Services
@using AgroSolutions.Dashboard.Models
@inject AlertService AlertService
@inject PropertyService PropertyService
@inject FieldService FieldService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ToastService ToastService
@implements IDisposable

<PageTitle>Dashboard - AgroSolutions</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <h2 class="mb-1">Dashboard de Alertas</h2>
        <p class="text-muted mb-0">
            Bem-vindo, @AuthState.UserName!
            @if (lastUpdate.HasValue)
            {
                <span class="ms-3">
                    🕒 Última atualização: @GetLastUpdateText()
                </span>
            }
        </p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="custom-switch">
            <label class="mb-0">Mostrar Resolvidos</label>
            <input class="form-check-input" type="checkbox"
                   checked="@showResolvedAlerts"
                   @onchange="e => { showResolvedAlerts = (bool)e.Value; StateHasChanged(); }">
        </div>
        <button class="btn btn-modern btn-modern-primary" @onclick="LoadData">
            🔄 Atualizar
        </button>
    </div>
</div>

<div class="filter-section mb-4">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">🔍 Propriedade:</label>
            <select class="form-select" @onchange="OnPropertyFilterChanged">
                <option value="">Selecione a Propriedade</option>
                @foreach (var property in userProperties)
                {
                    <option value="@property.Id">@property.Name</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold">Talhão:</label>
            <select class="form-select" @onchange="OnFieldFilterChanged" disabled="@(selectedPropertyId == null)">
                <option value="">Selecione o Talhão</option>
                @foreach (var field in filteredFields)
                {
                    <option value="@field.Id">@field.Name (@field.Culture)</option>
                }
            </select>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
        <p class="mt-3 text-muted">Carregando seus dados...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        <strong>Erro:</strong> @errorMessage
    </div>
}
else if (userFields.Count == 0)
{
    <div class="alert alert-warning">
        <strong>Nenhum talhão cadastrado.</strong> Cadastre propriedades e talhões para começar a monitorar.
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card stat-card-danger">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">⚠️ Alertas Críticos</div>
                        <div class="stat-number">@GetFilteredAlerts().Count(a => a.Severity == "Alta" && !a.IsResolved)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-warning">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">⚡ Alertas Médios</div>
                        <div class="stat-number">@GetFilteredAlerts().Count(a => a.Severity == "Média" && !a.IsResolved)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-success">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">✓ Resolvidos</div>
                        <div class="stat-number">@allAlerts.Count(a => a.IsResolved)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-info">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-label">🌾 Total de Talhões</div>
                        <div class="stat-number">@userFields.Count</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (GetFilteredAlerts().Count() == 0)
    {
        <div class="alert alert-info">
            <strong>Nenhum alerta encontrado.</strong> @(showResolvedAlerts ? "Todas as suas condições estão normais!" : "Ative 'Mostrar Resolvidos' para ver todos os alertas.")
        </div>
    }
    else
    {
        <div class="modern-table">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th @onclick='() => SortBy("Property")' style="cursor: pointer;">
                            Propriedade @GetSortIcon("Property")
                        </th>
                        <th @onclick='() => SortBy("Field")' style="cursor: pointer;">
                            Nome do Talhão @GetSortIcon("Field")
                        </th>
                        <th @onclick='() => SortBy("Type")' style="cursor: pointer;">
                            Tipo @GetSortIcon("Type")
                        </th>
                        <th @onclick='() => SortBy("Severity")' style="cursor: pointer;">
                            Severidade @GetSortIcon("Severity")
                        </th>
                        <th>Mensagem</th>
                        <th @onclick='() => SortBy("CreatedAt")' style="cursor: pointer;">
                            DataHora @GetSortIcon("CreatedAt")
                        </th>
                        <th @onclick='() => SortBy("Status")' style="cursor: pointer;">
                            Status @GetSortIcon("Status")
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var alert in GetFilteredAlerts())
                    {
                        var field = userFields.FirstOrDefault(f => f.Id == alert.FieldId);
                        var property = userProperties.FirstOrDefault(p => p.Id == field?.RuralPropertyId);
                        <tr>
                            <td>
                                <strong>@(property?.Name ?? "Desconhecida")</strong>
                            </td>
                            <td>
                                <strong>@(field?.Name ?? "Desconhecido")</strong><br />
                                <small class="text-muted">@(field?.Culture ?? "")</small>
                            </td>
                            <td>
                                <span class="badge badge-modern @GetBadgeClass(alert.Type)">
                                    @GetAlertTypeLabel(alert.Type)
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-modern @GetSeverityBadgeClass(alert.Severity)">
                                    @alert.Severity
                                </span>
                            </td>
                            <td>@alert.Message</td>
                            <td>@alert.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (alert.IsResolved)
                                {
                                    <span class="badge badge-modern bg-success">Resolvido</span>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-modern-success" @onclick="() => ShowConfirmResolve(alert.Id)">
                                        Resolver
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (showConfirmModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar Resolução</h5>
                    <button type="button" class="btn-close" @onclick="CloseConfirmModal"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja marcar este alerta como resolvido?</p>
                    <p class="text-muted mb-0">Esta ação não pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseConfirmModal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmResolve">
                        Sim, Resolver
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Alert> alerts = new();
    private List<Alert> allAlerts = new();
    private List<Property> userProperties = new();
    private List<Field> userFields = new();
    private List<Field> filteredFields = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string sortColumn = "CreatedAt";
    private bool sortAscending = false;
    private DateTime? lastUpdate = null;

    private Guid? selectedPropertyId = null;
    private Guid? selectedFieldId = null;
    private bool showResolvedAlerts = true;
    private bool showConfirmModal = false;
    private Guid? alertToResolve = null;
    private System.Threading.Timer? updateTimer;

    private string GetLastUpdateText()
    {
        if (!lastUpdate.HasValue) return "";

        var timeSpan = DateTime.Now - lastUpdate.Value;

        if (timeSpan.TotalSeconds < 60)
            return "há alguns segundos";
        else if (timeSpan.TotalMinutes < 60)
            return $"há {(int)timeSpan.TotalMinutes} minuto(s)";
        else if (timeSpan.TotalHours < 24)
            return $"há {(int)timeSpan.TotalHours} hora(s)";
        else
            return lastUpdate.Value.ToString("dd/MM/yyyy HH:mm");
    }

    protected override async Task OnInitializedAsync()
    {
        while (!AuthState.IsInitialized)
        {
            await Task.Delay(50);
        }

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    protected override void OnInitialized()
    {
        updateTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(() => StateHasChanged());
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    public void Dispose()
    {
        updateTimer?.Dispose();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            userProperties = await PropertyService.GetUserPropertiesAsync();

            if (userProperties.Count == 0)
            {
                alerts = new List<Alert>();
                allAlerts = new List<Alert>();
                userFields = new List<Field>();
                return;
            }

            var propertyIds = userProperties.Select(p => p.Id).ToList();
            userFields = await FieldService.GetAllUserFieldsAsync(propertyIds);

            if (userFields.Count == 0)
            {
                alerts = new List<Alert>();
                allAlerts = new List<Alert>();
                return;
            }

            var tempAlerts = new List<Alert>();
            foreach (var field in userFields)
            {
                var fieldAlerts = await AlertService.GetAlertsAsync(field.Id);
                tempAlerts.AddRange(fieldAlerts);
            }

            allAlerts = tempAlerts;
            alerts = allAlerts;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            lastUpdate = DateTime.Now;
        }
    }

    private async Task OnPropertyFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();

        if (string.IsNullOrEmpty(value))
        {
            selectedPropertyId = null;
            selectedFieldId = null;
            filteredFields = new List<Field>();
            alerts = allAlerts;
        }
        else
        {
            selectedPropertyId = Guid.Parse(value);
            selectedFieldId = null;

            filteredFields = userFields.Where(f => f.RuralPropertyId == selectedPropertyId).ToList();

            var fieldIds = filteredFields.Select(f => f.Id).ToList();
            alerts = allAlerts.Where(a => fieldIds.Contains(a.FieldId)).ToList();
        }

        StateHasChanged();
    }

    private void OnFieldFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();

        if (string.IsNullOrEmpty(value))
        {
            if (selectedPropertyId.HasValue)
            {
                var fieldIds = filteredFields.Select(f => f.Id).ToList();
                alerts = allAlerts.Where(a => fieldIds.Contains(a.FieldId)).ToList();
            }
            else
            {
                alerts = allAlerts;
            }
            selectedFieldId = null;
        }
        else
        {
            selectedFieldId = Guid.Parse(value);
            alerts = allAlerts.Where(a => a.FieldId == selectedFieldId).ToList();
        }

        StateHasChanged();
    }

    private void ShowConfirmResolve(Guid alertId)
    {
        alertToResolve = alertId;
        showConfirmModal = true;
    }

    private void CloseConfirmModal()
    {
        alertToResolve = null;
        showConfirmModal = false;
    }

    private async Task ConfirmResolve()
    {
        if (alertToResolve.HasValue)
        {
            await ResolveAlert(alertToResolve.Value);
        }
        CloseConfirmModal();
    }

    private async Task ResolveAlert(Guid alertId)
    {
        try
        {
            var success = await AlertService.ResolveAlertAsync(alertId);

            if (success)
            {
                var alert = allAlerts.FirstOrDefault(a => a.Id == alertId);
                if (alert != null)
                {
                    alert.IsResolved = true;
                }

                var filteredAlert = alerts.FirstOrDefault(a => a.Id == alertId);
                if (filteredAlert != null)
                {
                    filteredAlert.IsResolved = true;
                }

                ToastService.ShowSuccess("Alerta resolvido com sucesso!");
                StateHasChanged();
            }
            else
            {
                ToastService.ShowError("Erro ao resolver alerta");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
    }

    private IEnumerable<Alert> GetFilteredAlerts()
    {
        var filtered = alerts.AsEnumerable();

        if (!showResolvedAlerts)
        {
            filtered = filtered.Where(a => !a.IsResolved);
        }

        // Aplicar ordenação
        filtered = sortColumn switch
        {
            "Property" => sortAscending
                ? filtered.OrderBy(a => userProperties.FirstOrDefault(p => p.Id == userFields.FirstOrDefault(f => f.Id == a.FieldId)?.RuralPropertyId)?.Name)
                : filtered.OrderByDescending(a => userProperties.FirstOrDefault(p => p.Id == userFields.FirstOrDefault(f => f.Id == a.FieldId)?.RuralPropertyId)?.Name),
            "Field" => sortAscending
                ? filtered.OrderBy(a => userFields.FirstOrDefault(f => f.Id == a.FieldId)?.Name)
                : filtered.OrderByDescending(a => userFields.FirstOrDefault(f => f.Id == a.FieldId)?.Name),
            "Type" => sortAscending
                ? filtered.OrderBy(a => a.Type)
                : filtered.OrderByDescending(a => a.Type),
            "Severity" => sortAscending
                ? filtered.OrderBy(a => a.Severity)
                : filtered.OrderByDescending(a => a.Severity),
            "CreatedAt" => sortAscending
                ? filtered.OrderBy(a => a.CreatedAt)
                : filtered.OrderByDescending(a => a.CreatedAt),
            "Status" => sortAscending
                ? filtered.OrderBy(a => a.IsResolved)
                : filtered.OrderByDescending(a => a.IsResolved),
            _ => filtered.OrderByDescending(a => a.CreatedAt)
        };

        return filtered;
    }

    private string GetBadgeClass(string type)
    {
        return type switch
        {
            "Seca" => "bg-danger",
            "AltaTemperatura" => "bg-warning",
            "ChuvaForte" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetSeverityBadgeClass(string severity)
    {
        return severity switch
        {
            "Alta" => "bg-danger",
            "Média" => "bg-warning",
            _ => "bg-secondary"
        };
    }

    private string GetAlertTypeLabel(string type)
    {
        return type switch
        {
            "Seca" => "Praga",
            "AltaTemperatura" => "Umidade",
            "ChuvaForte" => "Doença",
            _ => type
        };
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column) return "⇅";
        return sortAscending ? "▲" : "▼";
    }
}