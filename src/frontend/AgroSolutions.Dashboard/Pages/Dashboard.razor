@page "/dashboard"
@using AgroSolutions.Dashboard.Services
@using AgroSolutions.Dashboard.Models
@inject AlertService AlertService
@inject PropertyService PropertyService
@inject FieldService FieldService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>Dashboard - AgroSolutions</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2>Dashboard de Alertas</h2>
            <p class="text-muted">Bem-vindo, @AuthState.UserName! Monitoramento das suas propriedades</p>
        </div>
        <div class="col-auto">
            <div class="form-check form-switch me-3 d-inline-block">
                <input class="form-check-input" type="checkbox" id="showResolved"
                       checked="@showResolvedAlerts" @onchange="e => showResolvedAlerts = (bool)e.Value">
                <label class="form-check-label" for="showResolved">
                    Mostrar Resolvidos
                </label>
            </div>
            <button class="btn btn-primary" @onclick="LoadData">
                <span>🔄 Atualizar</span>
            </button>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Filtrar por Propriedade</label>
            <select class="form-select" @onchange="OnPropertyFilterChanged">
                <option value="">Todas as Propriedades</option>
                @foreach (var property in userProperties)
                {
                    <option value="@property.Id">@property.Name</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Filtrar por Talhão</label>
            <select class="form-select" @onchange="OnFieldFilterChanged" disabled="@(selectedPropertyId == null)">
                <option value="">Todos os Talhões</option>
                @foreach (var field in filteredFields)
                {
                    <option value="@field.Id">@field.Name (@field.Culture)</option>
                }
            </select>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p>Carregando seus dados...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <strong>Erro:</strong> @errorMessage
        </div>
    }
    else if (userFields.Count == 0)
    {
        <div class="alert alert-warning">
            <strong>Nenhum talhão cadastrado.</strong> Cadastre propriedades e talhões para começar a monitorar.
        </div>
    }
    else if (GetFilteredAlerts().Count() == 0)
    {
        <div class="alert alert-info">
            <strong>Nenhum alerta encontrado.</strong> @(showResolvedAlerts ? "Todas as suas condições estão normais!" : "Desmarque 'Mostrar Resolvidos' para ver todos os alertas.")
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Alertas Críticos</h6>
                                <h2 class="mb-0 text-danger">@GetFilteredAlerts().Count(a => a.Severity == "Alta" && !a.IsResolved)</h2>
                            </div>
                            <div class="text-danger" style="font-size: 2.5rem;">⚠️</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Alertas Médios</h6>
                                <h2 class="mb-0 text-warning">@GetFilteredAlerts().Count(a => a.Severity == "Média" && !a.IsResolved)</h2>
                            </div>
                            <div class="text-warning" style="font-size: 2.5rem;">⚡</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Resolvidos</h6>
                                <h2 class="mb-0 text-success">@allAlerts.Count(a => a.IsResolved)</h2>
                            </div>
                            <div class="text-success" style="font-size: 2.5rem;">✓</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Total de Talhões</h6>
                                <h2 class="mb-0 text-info">@userFields.Count</h2>
                            </div>
                            <div class="text-info" style="font-size: 2.5rem;">🌾</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5>Alertas dos Seus Talhões</h5>
                <small class="text-muted">Monitorando @userFields.Count talhão(ões) em @userProperties.Count propriedade(s)</small>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Talhão</th>
                                <th>Tipo</th>
                                <th>Severidade</th>
                                <th>Mensagem</th>
                                <th>Data/Hora</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var alert in GetFilteredAlerts())
                            {
                                var field = userFields.FirstOrDefault(f => f.Id == alert.FieldId);
                                <tr class="@GetRowClass(alert)">
                                    <td>
                                        <strong>@(field?.Name ?? "Desconhecido")</strong><br />
                                        <small class="text-muted">@(field?.Culture ?? "")</small>
                                    </td>
                                    <td>
                                        <span class="badge @GetBadgeClass(alert.Type)">
                                            @GetAlertIcon(alert.Type) @alert.Type
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetSeverityClass(alert.Severity)">
                                            @alert.Severity
                                        </span>
                                    </td>
                                    <td>@alert.Message</td>
                                    <td>@alert.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (alert.IsResolved)
                                        {
                                            <span class="badge bg-success">✓ Resolvido</span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => ShowConfirmResolve(alert.Id)">
                                                Resolver
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showConfirmModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar Resolução</h5>
                    <button type="button" class="btn-close" @onclick="CloseConfirmModal"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja marcar este alerta como resolvido?</p>
                    <p class="text-muted mb-0">Esta ação não pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseConfirmModal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmResolve">
                        Sim, Resolver
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Alert> alerts = new();
    private List<Alert> allAlerts = new();
    private List<Property> userProperties = new();
    private List<Field> userFields = new();
    private List<Field> filteredFields = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    private Guid? selectedPropertyId = null;
    private Guid? selectedFieldId = null;
    private bool showResolvedAlerts = true;
    private bool showConfirmModal = false;
    private Guid? alertToResolve = null;

    protected override async Task OnInitializedAsync()
    {
        // Aguardar inicialização do AuthState
        while (!AuthState.IsInitialized)
        {
            await Task.Delay(50);
        }

        // Redirecionar se não estiver autenticado
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            Console.WriteLine($"[DEBUG] UserId: {AuthState.UserId}");

            // 1. Buscar propriedades do usuário
            userProperties = await PropertyService.GetUserPropertiesAsync();
            Console.WriteLine($"[DEBUG] Properties count: {userProperties.Count}");

            if (userProperties.Count == 0)
            {
                alerts = new List<Alert>();
                allAlerts = new List<Alert>();
                userFields = new List<Field>();
                return;
            }

            // 2. Buscar todos os talhões das propriedades do usuário
            var propertyIds = userProperties.Select(p => p.Id).ToList();
            Console.WriteLine($"[DEBUG] Property IDs: {string.Join(", ", propertyIds)}");

            userFields = await FieldService.GetAllUserFieldsAsync(propertyIds);
            Console.WriteLine($"[DEBUG] Fields count: {userFields.Count}");
            foreach (var field in userFields)
            {
                Console.WriteLine($"[DEBUG] Field ID: {field.Id}, Name: {field.Name}");
            }

            if (userFields.Count == 0)
            {
                alerts = new List<Alert>();
                allAlerts = new List<Alert>();
                return;
            }

            // 3. Buscar alertas apenas dos talhões do usuário
            var tempAlerts = new List<Alert>();
            foreach (var field in userFields)
            {
                Console.WriteLine($"[DEBUG] Buscando alertas para field: {field.Id}");
                var fieldAlerts = await AlertService.GetAlertsAsync(field.Id);
                Console.WriteLine($"[DEBUG] Alertas encontrados: {fieldAlerts.Count}");
                tempAlerts.AddRange(fieldAlerts);
            }

            Console.WriteLine($"[DEBUG] Total de alertas: {tempAlerts.Count}");
            allAlerts = tempAlerts;
            alerts = allAlerts;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"[DEBUG ERROR] {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPropertyFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();

        if (string.IsNullOrEmpty(value))
        {
            selectedPropertyId = null;
            selectedFieldId = null;
            filteredFields = new List<Field>();
            alerts = allAlerts;
        }
        else
        {
            selectedPropertyId = Guid.Parse(value);
            selectedFieldId = null;

            // Filtrar talhões da propriedade selecionada
            filteredFields = userFields.Where(f => f.RuralPropertyId == selectedPropertyId).ToList();

            // Filtrar alertas dos talhões da propriedade
            var fieldIds = filteredFields.Select(f => f.Id).ToList();
            alerts = allAlerts.Where(a => fieldIds.Contains(a.FieldId)).ToList();
        }

        StateHasChanged();
    }

    private void OnFieldFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();

        if (string.IsNullOrEmpty(value))
        {
            // Mostrar todos os alertas da propriedade selecionada
            if (selectedPropertyId.HasValue)
            {
                var fieldIds = filteredFields.Select(f => f.Id).ToList();
                alerts = allAlerts.Where(a => fieldIds.Contains(a.FieldId)).ToList();
            }
            else
            {
                alerts = allAlerts;
            }
            selectedFieldId = null;
        }
        else
        {
            selectedFieldId = Guid.Parse(value);

            // Filtrar alertas apenas do talhão selecionado
            alerts = allAlerts.Where(a => a.FieldId == selectedFieldId).ToList();
        }

        StateHasChanged();
    }

    private void ShowConfirmResolve(Guid alertId)
    {
        alertToResolve = alertId;
        showConfirmModal = true;
    }

    private void CloseConfirmModal()
    {
        alertToResolve = null;
        showConfirmModal = false;
    }

    private async Task ConfirmResolve()
    {
        if (alertToResolve.HasValue)
        {
            await ResolveAlert(alertToResolve.Value);
        }
        CloseConfirmModal();
    }

    private async Task ResolveAlert(Guid alertId)
    {
        try
        {
            var success = await AlertService.ResolveAlertAsync(alertId);

            if (success)
            {
                // Atualizar a lista local em allAlerts
                var alert = allAlerts.FirstOrDefault(a => a.Id == alertId);
                if (alert != null)
                {
                    alert.IsResolved = true;
                }

                // Atualizar também na lista filtrada
                var filteredAlert = alerts.FirstOrDefault(a => a.Id == alertId);
                if (filteredAlert != null)
                {
                    filteredAlert.IsResolved = true;
                }

                ToastService.ShowSuccess("Alerta resolvido com sucesso!");
                StateHasChanged();
            }
            else
            {
                ToastService.ShowError("Erro ao resolver alerta");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Erro: {ex.Message}");
        }
    }

    private IEnumerable<Alert> GetFilteredAlerts()
    {
        var filtered = alerts.AsEnumerable();

        if (!showResolvedAlerts)
        {
            filtered = filtered.Where(a => !a.IsResolved);
        }

        return filtered.OrderByDescending(a => a.CreatedAt);
    }

    private string GetRowClass(Alert alert)
    {
        if (alert.IsResolved) return "table-secondary";
        return alert.Severity == "Alta" ? "table-danger" : "table-warning";
    }

    private string GetBadgeClass(string type)
    {
        return type switch
        {
            "Seca" => "bg-danger",
            "AltaTemperatura" => "bg-warning",
            "ChuvaForte" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetSeverityClass(string severity)
    {
        return severity switch
        {
            "Alta" => "bg-danger",
            "Média" => "bg-warning",
            _ => "bg-secondary"
        };
    }

    private string GetAlertIcon(string type)
    {
        return type switch
        {
            "Seca" => "💧",
            "AltaTemperatura" => "🌡️",
            "ChuvaForte" => "🌧️",
            _ => "⚠️"
        };
    }
}