@page "/register"
@layout PublicLayout
@using AgroSolutions.Dashboard.Services
@using AgroSolutions.Dashboard.Models
@using System.ComponentModel.DataAnnotations
@inject ToastService ToastService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Cadastro - AgroSolutions</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3>Criar Conta - AgroSolutions</h3>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <EditForm Model="@registerRequest" OnValidSubmit="@HandleRegister">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Nome Completo</label>
                            <InputText @bind-Value="registerRequest.Name" class="form-control" placeholder="João Silva" />
                            <ValidationMessage For="@(() => registerRequest.Name)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="registerRequest.Email" class="form-control" placeholder="seu@email.com" />
                            <ValidationMessage For="@(() => registerRequest.Email)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Senha</label>
                            <InputText type="password" @bind-Value="registerRequest.Password" class="form-control" placeholder="Mínimo 8 caracteres" />
                            <ValidationMessage For="@(() => registerRequest.Password)" class="text-danger" />
                            <small class="text-muted">A senha deve ter pelo menos 8 caracteres, 1 letra maiúscula, 1 número e 1 caractere especial</small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span>Cadastrando...</span>
                            }
                            else
                            {
                                <span>Criar Conta</span>
                            }
                        </button>
                    </EditForm>

                    <hr />
                    <p class="text-center mb-0">
                        Já tem uma conta? <a href="/login">Faça login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerRequest = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private class RegisterRequest
    {
        [Required(ErrorMessage = "Nome é obrigatório")]
        [MinLength(3, ErrorMessage = "Nome deve ter pelo menos 3 caracteres")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email é obrigatório")]
        [EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Senha é obrigatória")]
        [MinLength(8, ErrorMessage = "Senha deve ter pelo menos 8 caracteres")]
        [RegularExpression(@"^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[@$!%*?&#])[A-Za-z\d@$!%*?&#]{8,}$",
            ErrorMessage = "Senha deve conter: 1 maiúscula, 1 minúscula, 1 número e 1 caractere especial")]
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleRegister()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var success = await AuthService.RegisterAsync(registerRequest.Name, registerRequest.Email, registerRequest.Password);

            if (success)
            {
                // Mostrar toast e redirecionar imediatamente
                ToastService.ShowSuccess("Conta criada com sucesso!");
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = "Erro ao criar conta. Verifique os dados e tente novamente.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}